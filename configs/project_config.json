{
  "project": {
    "name": "Marine Biodiversity Ecosystem Health Assessment",
    "author": "Shri Harsan M",
    "institution": "SRM Institute",
    "version": "2.0",
    "date": "2026-03"
  },
  "indicator_classes": {
    "0": "butterflyfish",
    "1": "grouper",
    "2": "parrotfish",
    "3": "surgeonfish",
    "4": "damselfish",
    "5": "wrasse",
    "6": "triggerfish",
    "7": "angelfish"
  },
  "dataset": {
    "target_per_class": 800,
    "min_resolution": 480,
    "train_ratio": 0.85,
    "val_ratio": 0.08,
    "test_ratio": 0.07
  },
  "model": {
    "architecture": "yolov8s",
    "pretrained_weights": "yolov8s.pt",
    "image_size": 640,
    "batch_size": 16,
    "epochs": 100,
    "patience": 20,
    "optimizer": "AdamW",
    "lr0": 0.001,
    "lrf": 0.0001
  },
  "augmentation": {
    "hsv_h": 0.02,
    "hsv_s": 0.7,
    "hsv_v": 0.4,
    "horizontal_flip": 0.5,
    "rotation_degrees": 15,
    "brightness": 0.2,
    "contrast": 0.2,
    "gaussian_noise_sigma": 5
  }
}