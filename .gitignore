# ============================================================
#  Marine Biodiversity Ecosystem Assessment
#  .gitignore — Shri Harsan M | M.Tech Data Science | SRM
# ============================================================

# ── VIRTUAL ENVIRONMENT ──────────────────────────────────────
marine_venv/
venv/
env/
.env/
.venv/

# ── VIDEOS (too large for GitHub) ────────────────────────────
data/videos/
*.mp4
*.avi
*.mov
*.mkv
*.wmv

# ── LARGE BINARY MODEL FILES ─────────────────────────────────
# Use Git LFS or share via Google Drive link in README
*.pt
*.pth
*.onnx
*.engine
*.torchscript

# Exception: keep placeholder in models/weights/ and models/onnx/
!models/weights/.gitkeep
!models/onnx/.gitkeep

# ── RAW DATASETS (keep only standardized/) ───────────────────
dataset/raw/
dataset/augmented_train/
# Keep standardized splits (small label files only, not images)
# Uncomment below to also exclude image files from standardized:
# dataset/standardized/**/*.jpg
# dataset/standardized/**/*.jpeg
# dataset/standardized/**/*.png

# ── TRAINING RUN OUTPUTS ─────────────────────────────────────
results/detection/yolov8s_marine/
# Subfolders created by YOLOv8 training runs
runs/
train/
detect/

# ── DASHBOARD RUNTIME FILES (change every second) ────────────
results/dashboard/live_state.json
results/dashboard/session_log.csv
results/dashboard/session_log_dtr.csv
results/dashboard/image_test_log.csv
results/dashboard/cmd.json

# ── PYTHON CACHE ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── JUPYTER NOTEBOOKS ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS FILES ─────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── IDE / EDITOR ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.sln.docstates
*.swp
*.swo
*~

# ── LOGS (keep training_log.csv, ignore auto-generated) ──────
logs/*.log
logs/tmp/
*.log

# ── SCREENSHOTS & TEMP OUTPUTS ───────────────────────────────
results/dashboard/screenshots/
*.tmp
*.temp
temp/
tmp/

# ── ENVIRONMENT / SECRETS ────────────────────────────────────
.env
.env.local
*.env
config_local.py
secrets.py

# ── COMPILED / DIST ──────────────────────────────────────────
*.egg-info/
dist/
build/
*.egg
MANIFEST

# ── PYTEST / COVERAGE ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── WANDB / MLFLOW (if used) ─────────────────────────────────
wandb/
mlruns/
mlflow/

# ── NUMPY / PICKLE TEMP FILES ────────────────────────────────
*.npy
*.npz
*.pkl
*.pickle
# Exception: keep any saved model state files you explicitly want
!models/weights/*.pkl

# ── VALIDATION / DEGRADATION LARGE OUTPUTS ───────────────────
results/validation/degradation/*.png
# Keep the report JSONs and CSV
!results/validation/degradation/degradation_report.json
!results/validation/degradation/degradation_results.csv

dataset/augmented/
dataset/processed/
dataset/standardized/
dataset/raw/
dataset/augmented_train/
dataset/splits/
dataset/standardized/train/images/
dataset/standardized/val/images/
dataset/standardized/test/images/
dataset/processed/
